<script>
// ━━━ STATE ━━━
let currentCampaignType = 'slidedeck';
let generatedPrompts = null;

// ━━━ INIT ━━━
document.addEventListener('DOMContentLoaded', () => {
  const savedKey = localStorage.getItem('kimaru_cc_apikey');
  if (savedKey) {
    document.getElementById('input-apikey').value = savedKey;
    updateApiStatus(true);
  }
});

// ━━━ SETTINGS ━━━
function openSettings() {
  document.getElementById('settings-modal').classList.add('active');
}
function closeSettings() {
  document.getElementById('settings-modal').classList.remove('active');
}
function saveApiKey() {
  const key = document.getElementById('input-apikey').value.trim();
  if (!key) {
    showToast('❌ APIキーを入力してください', 'error');
    return;
  }
  localStorage.setItem('kimaru_cc_apikey', key);
  updateApiStatus(true);
  closeSettings();
  showToast('✅ APIキーを保存しました');
}
function updateApiStatus(active) {
  const dot = document.getElementById('api-status-dot');
  const text = document.getElementById('api-status-text');
  if (active) {
    dot.className = 'absolute -bottom-1 -right-1 w-3 h-3 bg-secondary rounded-full border-2 border-[#1c1b1b] animate-pulse';
    text.textContent = 'AIエンジン稼働中';
  } else {
    dot.className = 'absolute -bottom-1 -right-1 w-3 h-3 bg-[#555] rounded-full border-2 border-[#1c1b1b]';
    text.textContent = 'API未設定';
  }
}

// ━━━ CAMPAIGN TYPE SEGMENT ━━━
function selectCampaignType(btn, type) {
  currentCampaignType = type;
  document.querySelectorAll('.segment-btn').forEach(b => {
    b.classList.remove('active', 'font-bold', 'text-on-primary-container', 'bg-surface-bright/20', 'backdrop-blur-md', 'rounded-lg', 'shadow-xl', 'ring-1', 'ring-primary/20');
    b.classList.add('text-on-surface-variant');
  });
  btn.classList.remove('text-on-surface-variant');
  btn.classList.add('active', 'font-bold', 'text-on-primary-container', 'bg-surface-bright/20', 'backdrop-blur-md', 'rounded-lg', 'shadow-xl', 'ring-1', 'ring-primary/20');
}

// ━━━ COPY TO CLIPBOARD ━━━
async function copyToClipboard(text, btnElement) {
  try {
    await navigator.clipboard.writeText(text);
    // Show feedback
    const feedback = btnElement.parentElement.querySelector('.copy-feedback');
    if (feedback) {
      feedback.classList.add('show');
      setTimeout(() => feedback.classList.remove('show'), 1500);
    }
    showToast('📋 コピーしました！');
  } catch(e) {
    // Fallback
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('📋 コピーしました！');
  }
}

// ━━━ TOAST ━━━
function showToast(message, type = 'success') {
  const toast = document.getElementById('toast');
  toast.textContent = message;
  toast.style.borderColor = type === 'error' ? 'rgba(255,180,171,0.3)' : 'rgba(0,242,255,0.3)';
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2500);
}

// =========================================================================
// 🚀 Gemini API 確実接続テンプレート (2026年最新版・JSON強制出力対応)
// 【鉄則1】 最新モデル「gemini-2.5-flash」を指定すること
// 【鉄則2】 maxOutputTokens: 4096 を確保すること
// 【鉄則3】 responseMimeType: "application/json" を指定し、JSON形式を強制すること
// 【鉄則4】 AIが返す余分なマークダウン（```json 等）を除去してからパースすること
// =========================================================================
const GEMINI_MODEL = "gemini-2.5-flash";
const MAX_OUTPUT_TOKENS = 4096;

// ━━━ GENERATE PROMPTS ━━━
async function generatePrompts() {
  const apiKey = localStorage.getItem('kimaru_cc_apikey');
  if (!apiKey) {
    openSettings();
    showToast('⚙️ まずAPIキーを設定してください', 'error');
    return;
  }

  const goal = document.getElementById('input-goal').value.trim();
  const strengths = document.getElementById('input-strengths').value.trim();
  const framework = document.getElementById('input-framework').value.trim();

  if (!goal) {
    showToast('❌ プロジェクト目標を入力してください', 'error');
    document.getElementById('input-goal').focus();
    return;
  }

  const btn = document.getElementById('btn-generate');
  const originalHTML = btn.innerHTML;

  // Show loading state
  btn.innerHTML = '<span class="loading-spinner"></span> 生成中...';
  btn.classList.add('btn-generating');
  document.getElementById('placeholder-state').classList.add('hidden');
  document.getElementById('generated-cards').classList.add('hidden');
  document.getElementById('loading-state').classList.remove('hidden');
  document.getElementById('prompt-status').innerHTML = '<span class="loading-spinner" style="width:8px;height:8px;border-width:1.5px;"></span> <span class="text-primary-container">生成中...</span>';

  // ━━━ 10ステップ営業ロジック（Card 1 のシステムプロンプトに埋め込む指示） ━━━
  const frameworkLine = framework
    ? `ユーザー独自フレームワーク「${framework}」を優先し、全9枚程度の骨子を作成`
    : '論理的な流れで全9枚程度の骨子を作成';

  const slideLogic10Steps = `以下の10ステップに従い、スライド資料の構成を作成せよ。
①結論を1文で固定
②冒頭3秒で読む価値を作る（数字・比較・損失回避の切り口で3案）
③情報を論点ごとに仕分ける（課題/原因/解決策/根拠データ/事例/導入手順/費用）
④相手の不安要素を先回りして潰す（不安に思う質問10個と回答の要点）
⑤強み（${strengths || 'ローラーストーン/シメントアート/斑ウォール等'}）を軸にした競合比較表を作る
⑥${frameworkLine}
⑦1スライド1メッセージ（タイトル＋箇条書き最大3点）
⑧デザインルール（シンプル・余白多め・1枚に結論は1つ）の指定
⑨断言系の刺さる言い回しに整える
⑩最後に3つの即決アクションを提示`;

  // ━━━ 3枚すべてをGemini APIで生成するシステムプロンプト ━━━
  const prompt = `あなたは、外構・リフォーム業界（ローラーストーン、シメントアート、フジワラ化学の斑ウォールなど特殊施工）に精通したトップレベルのAIマーケティングコンサルタントです。

以下の入力内容をもとに、3つの異なる目的に最適化されたAIプロンプトを日本語で生成してください。
各プロンプトは、コピーしてそのまま別のAIツールに貼り付けて使えるレベルの完成度で出力してください。

【プロジェクト目標・ターゲット】: ${goal}
【コア強み・素材】: ${strengths || '特殊施工の高級仕上がりと他社との差別化'}
${framework ? '【カスタムフレームワーク】: ' + framework : ''}

━━━━━━━━━━━━━━━━━━━━━━━
【Card 1: NotebookLM用 スライド構成プロンプト】
以下の「10の営業ロジック」を完全に組み込み、ユーザーの商材の強みが自動で反映された、
NotebookLMにそのまま貼り付けられるスライド構成マスタープロンプトを生成せよ。

${slideLogic10Steps}

前提条件として以下を組み込むこと：
・資料の目的：「${goal}」
・想定ターゲット：「${goal}」に関わるステークホルダー
・最大の強み：「${strengths || '特殊施工技術による唯一無二の仕上がり'}」
━━━━━━━━━━━━━━━━━━━━━━━
【Card 2: Freepik AI用 パース画像生成プロンプト】
実写・高画質指定で、施工のBefore/Afterや完成イメージを生成するための
Freepik AI画像生成プロンプトを作成せよ。
素材の質感（${strengths || '特殊仕上げ素材'}）、自然光・照明、
カメラアングル、解像度などの詳細指示を含むこと。
━━━━━━━━━━━━━━━━━━━━━━━
【Card 3: Stitch用 LPデザイン生成プロンプト】
ランディングページのデザインとコピーを自動生成するための
Stitch AIプロンプトを作成せよ。
ターゲットに刺さるヘッドコピー、サブコピー、CTA、構成セクション、
配色指示、レスポンシブ対応などの指示を含むこと。
━━━━━━━━━━━━━━━━━━━━━━━

━━━ 出力ルール（厳守） ━━━
以下のJSON形式で出力してください。JSON以外の文字は一切出力しないでください。
各contentは500文字以上で、コピペですぐ使える完成形プロンプトとして出力すること。

{
  "prompts": [
    {
      "id": "master_slide",
      "title": "📋 NotebookLM用 スライド構成プロンプト",
      "badge": "10ステップ",
      "description": "10の営業ロジックを組み込んだ、スライド資料の構成マスタープロンプト",
      "content": "(10ステップの営業ロジックに基づいた完全なスライド構成プロンプトを出力)"
    },
    {
      "id": "freepik",
      "title": "🎨 Freepik AIパース画像プロンプト",
      "badge": "実写・高画質",
      "description": "施工イメージを実写クオリティで生成するAI画像プロンプト",
      "content": "(実写・高画質指定の詳細な画像生成プロンプトを出力)"
    },
    {
      "id": "lp_stitch",
      "title": "🖥️ Stitch用 LPデザインプロンプト",
      "badge": "LP生成",
      "description": "ランディングページのデザインとコピーを自動生成するプロンプト",
      "content": "(LP構成・コピー・デザイン指示を含む完全なプロンプトを出力)"
    }
  ]
}`;

  try {
    // 【鉄則1】gemini-2.5-flash を直接指定
    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent?key=${apiKey}`;
    console.log("🚀 Using Model:", GEMINI_MODEL, "| maxOutputTokens:", MAX_OUTPUT_TOKENS);

    const res = await fetch(apiUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{ parts: [{ text: prompt }] }],
        generationConfig: {
          // 【鉄則3】JSON形式を強制
          responseMimeType: "application/json",
          // 【鉄則2】出力トークン確保
          maxOutputTokens: MAX_OUTPUT_TOKENS
        }
      })
    });

    const data = await res.json();

    if (!res.ok || data.error) {
      const errMsg = data.error ? data.error.message : res.statusText;
      const errCode = data.error ? data.error.code : res.status;
      let userMessage = `API Error (${errCode}): ${errMsg}`;
      if (errCode === 400) userMessage = 'APIキーが無効です。設定を確認してください。';
      else if (errCode === 403) userMessage = '権限エラー：APIキーの権限を確認してください。';
      else if (errCode === 404) userMessage = `モデル「${GEMINI_MODEL}」が見つかりません。`;
      else if (errCode === 429) userMessage = 'レートリミット超過。少し待ってから再試行してください。';
      throw new Error(userMessage);
    }

    if (!data.candidates || data.candidates.length === 0) {
      throw new Error("APIから空のレスポンスが返されました。");
    }

    let responseText = data.candidates[0].content.parts[0].text;
    console.log("📦 Raw API response:", responseText);

    // 【鉄則4】余分なマークダウン ```json ... ``` を除去してからパース
    responseText = responseText.trim();
    if (responseText.startsWith('```')) {
      const cleaned = responseText.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/,'');
      responseText = cleaned.trim();
    }

    let parsed;
    try {
      parsed = JSON.parse(responseText);
    } catch(e) {
      // フォールバック: 文中にJSON部分がある場合に抽出
      const jsonMatch = responseText.match(/\{[\s\S]*"prompts"[\s\S]*\}/);
      if (jsonMatch) {
        parsed = JSON.parse(jsonMatch[0]);
      } else {
        throw new Error("JSONパース失敗: " + e.message + "\n生データ先頭200文字: " + responseText.substring(0, 200));
      }
    }

    if (!parsed.prompts || !Array.isArray(parsed.prompts)) {
      throw new Error("レスポンスに prompts 配列が見つかりません。");
    }

    generatedPrompts = parsed.prompts;
    renderCards(generatedPrompts);

  } catch(err) {
    console.error("❌ Generation Error:", err);
    showToast('❌ ' + err.message, 'error');
    document.getElementById('loading-state').classList.add('hidden');
    document.getElementById('placeholder-state').classList.remove('hidden');
    document.getElementById('prompt-status').innerHTML = '<span class="w-2 h-2 bg-error rounded-full"></span> <span class="text-error">エラー発生</span>';
  } finally {
    btn.innerHTML = originalHTML;
    btn.classList.remove('btn-generating');
  }
}

// ━━━ RENDER CARDS ━━━
function renderCards(prompts) {
  document.getElementById('loading-state').classList.add('hidden');
  const container = document.getElementById('generated-cards');
  container.innerHTML = '';
  container.classList.remove('hidden');

  document.getElementById('prompt-status').innerHTML = `
    <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"></span>
    <span class="text-secondary animate-pulse">${prompts.length} 件のプロンプト準備完了</span>
  `;

  prompts.forEach((p, i) => {
    const isMasterSlide = p.id === 'master_slide';
    const isHighlighted = p.id === 'freepik';

    const card = document.createElement('div');
    card.className = 'card-animated';
    card.style.opacity = '0';

    if (isMasterSlide) {
      // ★ Card 1: マスタープロンプト — 特別な紫グラデーションスタイル
      card.innerHTML = `
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-secondary via-primary to-transparent rounded-2xl blur-xl opacity-25"></div>
          <div class="relative bg-surface-container rounded-xl p-6 border-l-4 border-secondary shadow-2xl">
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-headline font-bold text-secondary">${escapeHtml(p.title)}</h3>
                ${p.badge ? `<span class="bg-secondary/20 text-secondary text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-widest">${escapeHtml(p.badge)}</span>` : ''}
              </div>
              <div class="relative flex-shrink-0">
                <span class="copy-feedback">コピー完了！</span>
                <button onclick="copyToClipboard(generatedPrompts[${i}].content, this)" class="p-2 bg-secondary/10 rounded-lg text-secondary hover:bg-secondary hover:text-on-secondary transition-all group-hover:scale-110">
                  <span class="material-symbols-outlined text-sm">content_copy</span>
                </button>
              </div>
            </div>
            <p class="font-body text-xs text-on-surface-variant/60 mb-3">${escapeHtml(p.description)}</p>
            <div class="bg-surface-container-lowest p-4 rounded-lg border border-secondary/10 max-h-[400px] overflow-y-auto">
              <pre class="font-body text-sm text-on-surface leading-relaxed whitespace-pre-wrap break-words">${escapeHtml(p.content)}</pre>
            </div>
          </div>
        </div>`;
    } else if (isHighlighted) {
      card.innerHTML = `
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-primary to-transparent rounded-2xl blur-xl opacity-20"></div>
          <div class="relative bg-surface-container rounded-xl p-6 border-l-4 border-primary shadow-2xl">
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-headline font-bold text-primary">${escapeHtml(p.title)}</h3>
                ${p.badge ? `<span class="bg-primary-container/20 text-primary-container text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-widest">${escapeHtml(p.badge)}</span>` : ''}
              </div>
              <div class="relative flex-shrink-0">
                <span class="copy-feedback">コピー完了！</span>
                <button onclick="copyToClipboard(generatedPrompts[${i}].content, this)" class="p-2 bg-primary/10 rounded-lg text-primary hover:bg-primary hover:text-on-primary transition-all group-hover:scale-110">
                  <span class="material-symbols-outlined text-sm">content_copy</span>
                </button>
              </div>
            </div>
            <div class="bg-surface-container-lowest p-4 rounded-lg border border-white/5">
              <p class="font-body text-sm text-on-surface leading-relaxed">${escapeHtml(p.content)}</p>
            </div>
          </div>
        </div>`;
    } else {
      card.innerHTML = `
        <div class="glass-panel p-6 rounded-xl border border-white/5 hover:border-white/10 transition-colors group relative">
          <div class="flex justify-between items-start mb-4">
            <div>
              <h3 class="font-headline font-semibold text-on-surface">${escapeHtml(p.title)}</h3>
              ${p.badge ? `<span class="text-[10px] text-secondary mt-1 block">${escapeHtml(p.badge)}</span>` : ''}
            </div>
            <div class="relative flex-shrink-0">
              <span class="copy-feedback">コピー完了！</span>
              <button onclick="copyToClipboard(generatedPrompts[${i}].content, this)" class="p-2 bg-white/5 rounded-lg hover:bg-primary-container hover:text-on-primary transition-all">
                <span class="material-symbols-outlined text-sm">content_copy</span>
              </button>
            </div>
          </div>
          <p class="font-body text-sm text-on-surface-variant leading-relaxed">${escapeHtml(p.content)}</p>
        </div>`;
    }

    container.appendChild(card);
  });

  // Add "Copy All" button
  const copyAllDiv = document.createElement('div');
  copyAllDiv.className = 'card-animated mt-4';
  copyAllDiv.style.opacity = '0';
  copyAllDiv.innerHTML = `
    <button onclick="copyAllPrompts()" class="w-full py-3 border border-white/10 hover:border-primary/30 rounded-xl text-on-surface-variant hover:text-primary font-label text-sm font-medium transition-all flex items-center justify-center gap-2">
      <span class="material-symbols-outlined text-sm">select_all</span>
      すべてコピー
    </button>`;
  container.appendChild(copyAllDiv);
}

// ━━━ COPY ALL ━━━
async function copyAllPrompts() {
  if (!generatedPrompts) return;
  const allText = generatedPrompts.map((p, i) => 
    `━━━ ${i+1}. ${p.title} ━━━\n${p.content}`
  ).join('\n\n');
  try {
    await navigator.clipboard.writeText(allText);
    showToast('📋 3つのプロンプトをすべてコピーしました！');
  } catch(e) {
    const ta = document.createElement('textarea');
    ta.value = allText;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('📋 3つのプロンプトをすべてコピーしました！');
  }
}

// ━━━ UTILITY ━━━
function escapeHtml(str) {
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}
