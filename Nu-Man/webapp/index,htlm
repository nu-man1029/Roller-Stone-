  ::-webkit-scrollbar-thumb:hover { background: #555; }

  /* Loading spinner */
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(0,242,255,0.3); }
    50% { box-shadow: 0 0 40px rgba(0,242,255,0.6); }
